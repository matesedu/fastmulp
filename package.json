{
  "name": "fastmulp",
  "private": true,
  "license": "GPL-3.0-or-later",
  "scripts": {
    "fmt": "oxfmt .",
    "lint": "cargo clippy --workspace --all-targets -- -D warnings",
    "check": "cargo check --workspace --all-targets",
    "test": "cargo test --workspace --lib --tests --examples && cargo test -p fastmulp-core --doc && cargo test -p fastmulp-wasm --doc",
    "bench": "cargo bench -p fastmulp-core --bench parse",
    "release:patch": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:alpha": "./scripts/release.sh alpha",
    "release:beta": "./scripts/release.sh beta",
    "build:node": "cargo build -p fastmulp-napi --release",
    "build:wasm": "cargo build -p fastmulp-wasm --target wasm32-unknown-unknown --release"
  },
  "devDependencies": {
    "oxfmt": "^0.36.0"
  },
  "packageManager": "pnpm@10.30.1"
}
